<div class="page-container">

    <h1>Movies</h1>

    <div class="grid">
        <% @movies.each do |movie| %>
            <%= link_to movie_path(movie) do %>
                <div >
                    <h2><%= movie.title %></h2>
                </div>
            <% end %>
        <% end %>
    </div>
</div>

<% content_for :title, "Showing movie" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing movie</h1>

  <%= render @employee_movie %>

  <%= link_to "Edit this movie", edit_employee_movie_path(@employee_movie), class: "btn btn-secondary w-full sm:w-auto" %>
  <%= link_to "Back to movies", employee_movies_path, class: "btn btn-secondary w-full sm:w-auto mt-2 sm:mt-0 sm:ml-2" %>
  <%= button_to "Destroy this movie", employee_movie_path(@employee_movie), method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "btn btn-danger w-full", data: { turbo_confirm: "Are you sure?" } %>
</div>
